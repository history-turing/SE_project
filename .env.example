# Copy this file to `.env.local` for local Docker runs, or to `.env.production`
# on the server. Do not commit real secrets.

MYSQL_DATABASE=se_project
MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-root-password
REDIS_PASSWORD=replace-with-a-strong-redis-password

FRONTEND_PORT=80
VITE_API_BASE_URL=/api/v1
TREEHOLE_SERVER_PORT=8080
TREEHOLE_SQL_INIT_MODE=never

# Local development can keep this true when SMTP is unavailable.
# Production should set this to false and provide real SMTP credentials.
TREEHOLE_AUTH_MOCK_EMAIL_ENABLED=true
TREEHOLE_AUTH_EMAIL_SUFFIX=@whu.edu.cn
TREEHOLE_AUTH_EMAIL_CODE_TTL=5m
TREEHOLE_AUTH_EMAIL_SEND_COOLDOWN=60s
TREEHOLE_AUTH_SESSION_TTL=7d

# SMTP is optional only when mock email is enabled.
TREEHOLE_MAIL_HOST=smtp.example.com
TREEHOLE_MAIL_PORT=587
TREEHOLE_MAIL_USERNAME=replace-with-mail-username
TREEHOLE_MAIL_PASSWORD=replace-with-mail-password
TREEHOLE_MAIL_SMTP_AUTH=true
TREEHOLE_MAIL_SMTP_STARTTLS=true
TREEHOLE_MAIL_SMTP_STARTTLS_REQUIRED=false
TREEHOLE_MAIL_SMTP_SSL_ENABLE=false
TREEHOLE_MAIL_SMTP_SSL_TRUST=smtp.example.com
TREEHOLE_AUTH_MAIL_FROM=no-reply@example.com

# GitHub Actions remote deploy defaults.
TREEHOLE_DEPLOY_ENV_FILE=.env.production
TREEHOLE_COMPOSE_PROJECT=se_project
